---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/AboutTemp/Hero/Hero.astro";
import IntroIcon from "../components/AboutTemp/IntroIcon/IntroIcon.astro";
import AboutUs from "../components/AboutTemp/AboutUs/AboutUs.astro";
import ContentLinks from "../components/AboutTemp/ContentLinks/ContentLinks.astro";
import AboutBio from "../components/AboutTemp/AboutBio/AboutBio.astro";
import ImageRow from "../components/AboutTemp/ImageRow/ImageRow.astro";
import OutroHero from "../components/AboutTemp/OutroHero/OutroHero.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Intro_Icon_Query,
  About_Us_Query,
  Content_Links_Query,
  About_Bio_Query,
  Image_Row_Query,
  Outro_Hero_Query,
} from "../data/about/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query aboutTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
          template {
            ... on Template_About {
              aboutTemplate {
                ${Hero_Query}
                ${Intro_Icon_Query}
                ${About_Us_Query}
                ${Content_Links_Query}
                ${About_Bio_Query}
                ${Image_Row_Query}
                ${Outro_Hero_Query}
            }
          }                 
        }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { aboutTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
>
  <Hero data={aboutTemplate.hero} />
  <IntroIcon data={aboutTemplate.introIcon} />
  <AboutUs data={aboutTemplate.aboutUs} />
  <ContentLinks data={aboutTemplate.contentLinks} />
  <AboutBio data={aboutTemplate.aboutBio} />
  <ImageRow data={aboutTemplate.imageRow} />
  <OutroHero data={aboutTemplate.outroHero} />
</Layout>
