---
import Layout from "../layouts/Layout.astro";
import HeroIntro from "../components/PrivacyTemp/HeroIntro/HeroIntro.astro";
import MainContent from "../components/PrivacyTemp/MainContent/MainContent.astro";

import { Page_Seo_Query } from "../data/page/queries";

import {
  Hero_Intro_Query,
  Main_Content_Query,
} from "../data/privacyPolicy/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query privacyTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
            template {
                ... on Template_Privacy {
                templateName
                privacyPolicyPage {
                    ${Hero_Intro_Query}
                    ${Main_Content_Query}
                }
            }                 
        }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { privacyPolicyPage },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
>
  <HeroIntro data={privacyPolicyPage.heroIntro} />
  <MainContent data={privacyPolicyPage.mainContent} />
</Layout>
