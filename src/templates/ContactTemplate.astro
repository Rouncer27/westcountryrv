---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/ContactTemp/Hero/Hero.astro";
import IntroLinks from "../components/ContactTemp/IntroLinks/IntroLinks.astro";
import Address from "../components/ContactTemp/Address/Address.astro";
import OutroHero from "../components/ContactTemp/OutroHero/OutroHero.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Outro_Hero_Query,
  Address_Query,
  Intro_Links_Query,
} from "../data/contact/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query contactTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
          template {
            ... on Template_Contact {
              contactTemplate {
                ${Hero_Query}
                ${Intro_Links_Query}
                ${Address_Query}
                ${Outro_Hero_Query}
            }
          }                 
        }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { contactTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
>
  <Hero data={contactTemplate.hero} />
  <IntroLinks data={contactTemplate.introLinks} />
  <Address data={contactTemplate.address} />
  <OutroHero data={contactTemplate.outroHero} />
</Layout>
