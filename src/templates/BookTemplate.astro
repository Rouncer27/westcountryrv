---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/BookTemp/Hero/Hero.astro";
import BoldIntro from "../components/BookTemp/BoldIntro/BoldIntro.astro";
import MountainCallout from "../components/BookTemp/MountainCallout/MountainCallout.astro";
import BookingEmbed from "../components/BookTemp/BookingEmbed/BookingEmbed.astro";
import ImageRow from "../components/BookTemp/ImageRow/ImageRow.astro";
import PageQuote from "../components/BookTemp/PageQuote/PageQuote.astro";
import OutroHero from "../components/BookTemp/OutroHero/OutroHero.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Bold_Intro_Query,
  Mountain_Callout_Query,
  Image_Row_Query,
  Page_Quote_Query,
  Image_Row_Two_Query,
  Outro_Hero_Query,
} from "../data/book/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query bookTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
          template {
            ... on Template_Book {
              bookTemplate {
                ${Hero_Query}
                ${Bold_Intro_Query}
                ${Mountain_Callout_Query}
                ${Image_Row_Query}
                ${Page_Quote_Query}
                ${Image_Row_Two_Query}
                ${Outro_Hero_Query}
            }
          }                 
        }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { bookTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={false}
>
  <Hero data={bookTemplate.hero} />
  <BoldIntro data={bookTemplate.boldIntro} />
  <MountainCallout data={bookTemplate.mountainCallout} />
  <BookingEmbed />
  <ImageRow data={bookTemplate.imageRow} />
  <PageQuote data={bookTemplate.pageQuote} />
  <ImageRow data={bookTemplate.imageRowTwo} />
  <OutroHero data={bookTemplate.outroHero} />
</Layout>
