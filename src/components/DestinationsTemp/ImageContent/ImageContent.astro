---
import { Image } from "astro:assets";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./imageContent.scss";
import Headline from "../../common/shared/Headline.astro";
import Button from "../../common/shared/Button.astro";

const { image, title, content, buttonText, buttonLink } = Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";
---

<div class="image-content">
  <Wrapper classes="image-content-wrapper">
    <div class="image-content-image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
    <div class="image-content-main">
      <div class="image-content-main-title">
        <Headline ele="h2" hlstyle="two">{title}</Headline>
      </div>
      <div class="image-content-main-paragraphs" set:html={content} />
      <div class="image-content-main-link">
        <Button target="_blank" rel="noopener" ele="a" href={buttonLink}
          >{buttonText}</Button
        >
      </div>
    </div>
  </Wrapper>
</div>
