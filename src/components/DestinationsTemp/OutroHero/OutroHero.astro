---
import "./outroHero.scss";
import { Image } from "astro:assets";

const { image, content } = Astro.props.data;

const heroImageSrc = image?.node?.sourceUrl;
const heroAlt = image?.node?.altText || "";

import whiteTear from "../../../assets/white-tear-destinations.png";
---

<div class="outro-hero outro-hero-destinations">
  <div class="outro-hero-image">
    <div>
      <Image
        src={heroImageSrc}
        alt={heroAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
    <div>
      <div class="outro-hero-content" set:html={content} />
    </div>
  </div>
  <div class="outro-hero-graphic">
    <img src={whiteTear.src} alt={"Mountain background"} />
  </div>
</div>
