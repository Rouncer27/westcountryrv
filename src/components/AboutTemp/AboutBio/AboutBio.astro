---
import { Image } from "astro:assets";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./aboutBio.scss";
import Headline from "../../common/shared/Headline.astro";

const { image, title, bio } = Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";

import mountainsTear from "../../../assets/mountain-path-grey-about.png";
---

<div class="about-bio">
  <Wrapper classes="about-bio-wrapper">
    <div class="about-bio-image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
    <div class="about-bio-content">
      <div class="about-bio-content-title">
        <Headline ele="h2" hlstyl="one">{title}</Headline>
      </div>
      <div class="about-bio-content-bio" set:html={bio} />
    </div>
  </Wrapper>
  <div class="about-bio-graphic">
    <img src={mountainsTear.src} alt={"Mountain background"} />
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const trigger = document.querySelector(".about-bio");
  const imageOne = document.querySelector(".about-bio-image");
  const imageTwo = document.querySelector(".about-bio-content");

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: trigger,
      start: "top 50%",
      markers: false,
    },
  });

  tl.add("start")
    .fromTo(
      imageOne,
      { autoAlpha: 0, x: -200 },
      {
        duration: 1,
        autoAlpha: 1,
        x: 0,
        ease: "power2.out",
      },
    )
    .fromTo(
      imageTwo,
      { autoAlpha: 0, x: 200 },
      {
        duration: 1,
        autoAlpha: 1,
        x: 0,
        ease: "power2.out",
      },
      "start+=0.5",
    );
</script>
