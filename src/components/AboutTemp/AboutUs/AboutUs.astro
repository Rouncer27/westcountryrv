---
import Headline from "../../common/shared/Headline.astro";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./aboutUs.scss";

const { title, content } = Astro.props.data;
---

<div class="about-us">
  <Wrapper classes="about-us-wrapper">
    <div class="about-us-title">
      <Headline ele="h2" hlstyle="two">{title}</Headline>
    </div>
    <div class="about-us-content" set:html={content} />
  </Wrapper>
</div>
