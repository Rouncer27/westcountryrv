---
import { Image } from "astro:assets";
import "./hero.scss";

const { image } = Astro.props.data;

const heroImageSrc = image?.node?.sourceUrl;
const heroAlt = image?.node?.altText || "";

import heroMountain from "../../../assets/gray-tear-up-faq.png";
---

<div class="hero">
  <div class="hero-image">
    <Image
      src={heroImageSrc}
      alt={heroAlt}
      format="webp"
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      inferSize={true}
      class=""
    />
  </div>
  <div class="hero-graphic">
    <img src={heroMountain.src} alt={"Mountain background"} />
  </div>
</div>

<script>
  // @ts-nocheck
  import { gsap } from "gsap";
  const image = document.querySelector(".hero-image img");
  const tl = gsap.timeline();
  tl.add("start").from(image, { filter: "blur(100px)", duration: 1 }, "start");
</script>
